# ── Servidor ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Base de datos MySQL (Railway o cualquier MySQL) ────────────
DB_HOST=yamanote.proxy.rlwy.net
DB_USER=root
DB_PASSWORD=tu_password_aqui
DB_NAME=railway
DB_PORT=35567

# ── Autenticación JWT ──────────────────────────────────────────
# Generá uno seguro: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=tu_jwt_secret_aqui
JWT_EXPIRATION=30d

# ── API Key (para endpoints externos /api/v1) ──────────────────
# Generá uno seguro: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=tu_api_key_aqui

# ── Firebase Storage (para subida de archivos — opcional) ──────
FIREBASE_BUCKET=tu-proyecto.firebasestorage.app
FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# ── WhatsApp / Integración externa (opcional) ──────────────────
WHATSAPP_ID=
KAPSO_API_KEY=
