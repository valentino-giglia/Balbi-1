# ── Servidor ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Base de datos MySQL (Railway o cualquier MySQL) ────────────
DB_HOST=yamanote.proxy.rlwy.net
DB_USER=root
DB_PASSWORD=tu_password_aqui
DB_NAME=railway
DB_PORT=35567

# ── Autenticación JWT ──────────────────────────────────────────
# Generá uno seguro: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=tu_jwt_secret_aqui
JWT_EXPIRATION=30d

# ── API Key (para endpoints externos /api/v1) ──────────────────
# Generá uno seguro: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=tu_api_key_aqui

# ── Firebase Storage (para subida de archivos — opcional) ──────
FIREBASE_BUCKET=tu-proyecto.firebasestorage.app
FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# ── WhatsApp / Integración externa (opcional) ──────────────────
WHATSAPP_ID=
KAPSO_API_KEY=

# ── Google APIs (Calendar + Sheets) ───────────────────────────
# Pegá el JSON completo de la Service Account en una sola línea
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
# Opcional — si querés sobreescribir los IDs hardcodeados
GOOGLE_CALENDAR_ID=9ff2aa39daa03cb2d81fc552fe844c13a0b21e13862a32ff85be5372ab7b095f@group.calendar.google.com
GOOGLE_SHEET_ID=1QS8GtFG6-EISoIwQ-V9WO-_0CoOLP4lw3BJukLh-oPI
